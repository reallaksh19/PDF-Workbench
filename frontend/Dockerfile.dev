FROM node:20-alpine

WORKDIR /app

# Enable corepack for pnpm
RUN corepack enable

# Copy workspace configuration
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY frontend/package.json ./frontend/

# Install dependencies
RUN pnpm install

WORKDIR /app/frontend
EXPOSE 3000

CMD ["pnpm", "dev", "--host"]
